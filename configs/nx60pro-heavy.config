# Heavy profile fragment for Netcore N60 Pro.
#
# This is a "config fragment" (append-only) that focuses on common add-ons:
# - iStore (requires custom feeds in diy-part1)
# - Multi-WAN, VPN, DDNS, etc.

# NOTE: This profile is now represented as a composition of fragments under:
#   configs/fragments/
# Keep this file for backwards compatibility and quick inspection.

# Multi-WAN
CONFIG_PACKAGE_mwan3=y
CONFIG_PACKAGE_luci-app-mwan3=y
CONFIG_PACKAGE_luci-i18n-mwan3-zh-cn=y

# VPN / Tunnels
CONFIG_PACKAGE_zerotier=y
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y

# DNS / Proxy helpers (pick what you actually use)
CONFIG_PACKAGE_cloudflared=y

# AdGuardHome (binary is large; prefer 512M flash if you enable many plugins)
CONFIG_PACKAGE_adguardhome=y
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-i18n-adguardhome-zh-cn=y

# Storage / Filesystems (USB overlay scenarios)
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_fdisk=y

# QoL
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-i18n-ddns-zh-cn=y

