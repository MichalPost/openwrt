# PassWall2 (multi-protocol proxy suite)
#
# Feed required in feeds.conf.default:
#   src-git passwall_packages https://github.com/Openwrt-Passwall/openwrt-passwall-packages.git;main
#   src-git passwall2 https://github.com/Openwrt-Passwall/openwrt-passwall2.git;main
#
# Notes:
# - This fragment only enables the LuCI app + i18n.
# - Proxy core backends (xray-core / sing-box / etc.) can be installed later via iStore/opkg as needed.

CONFIG_PACKAGE_luci-app-passwall2=y
CONFIG_PACKAGE_luci-i18n-passwall2-zh-cn=y

