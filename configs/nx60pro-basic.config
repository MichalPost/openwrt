# Basic profile fragment for N60PRO.
#
# Keep this small for 128M flash devices: LuCI + core networking.

# NOTE: This profile is now represented as a composition of fragments under:
#   configs/fragments/
# Keep this file for backwards compatibility and quick inspection.

CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-opkg-zh-cn=y

CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_htop=y

