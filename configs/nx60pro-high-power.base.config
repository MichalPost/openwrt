# Baseline profile fragment for Netcore N60 Pro (high power).
#
# IMPORTANT: this file is a "config fragment" (it will be APPENDED to .config).
# The base .config is seeded from:
#   defconfig/nx60pro-ipailna-high-power.config
#
# Keep this baseline conservative: core LuCI + HTTPS + common tooling.

CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-opkg-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y

CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_openssl-util=y

# Useful for troubleshooting
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_iperf3=y


